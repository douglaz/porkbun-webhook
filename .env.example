PORKBUN_API_KEY=your-porkbun-api-key
PORKBUN_SECRET_API_KEY=your-porkbun-secret-api-key
PORKBUN_API_BASE=https://api.porkbun.com/api/json/v3
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8888
DOMAIN_FILTER=example.com,example.org
DRY_RUN=false
CACHE_TTL_SECONDS=60
HTTP_TIMEOUT_SECONDS=30
TRACE_REQUEST_BODIES=false
RUST_LOG=info
